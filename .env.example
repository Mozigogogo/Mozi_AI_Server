# ── MySQL（agent） ──
MYSQL_HOST=your_mysql_host
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=community
MYSQL_CHARSET=utf8mb4

# ── DeepSeek API ──
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ── 应用配置 ──
APP_NAME=Crypto Analyst Assistant
APP_VERSION=1.0.0
DEBUG=False

# ── API配置 ──
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ── Agent 数据获取 ──
KLINE_API_BASE=https://your-api-domain.com
DERIVATIVES_API_BASE=https://your-api-domain.com/derivatives

# ── Agent LLM ──
MAX_NEWS_ITEMS=100
KLINE_DAYS_LIMIT=30
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=1200

# ── CORS（前端直连本服务时配置，逗号分隔；设为 * 则允许任意来源但不带 Cookie） ──
CORS_ORIGINS=https://mozi-web-develop.up.railway.app,https://mozi-web-production.up.railway.app,http://localhost:3000

# ── Redis（BigOrder 大单对话必填） ──
REDIS_ENABLED=true
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password

# ── Bigorder MySQL ──
BIGORDER_MYSQL_HOST=your_mysql_host
BIGORDER_MYSQL_PORT=3306
BIGORDER_MYSQL_USER=root
BIGORDER_MYSQL_PASSWORD=your_mysql_password
BIGORDER_MYSQL_DATABASE=exchange

# ── Bigorder LLM ──
BIGORDER_DEEPSEEK_MODEL=deepseek-v4-flash

# ── Bigorder 引擎 ──
SCAN_INTERVAL=30
HISTORY_WINDOW_COUNT=288
SCORE_THRESHOLD_STRONG=70
SCORE_THRESHOLD_MEDIUM=50
FLOW_WINDOW_SECONDS=300
PRICE_WINDOW_SECONDS=900
